    .

## ============================================================
## Fundering
## ============================================================

## Fundering

data:vbf1
    a                                           imbor:8b7bbb81-3498-49a0-8e08-fe77b2db7657 ;   #'Paalfundering'
    nen3610:identificatie                        "vbf1" ;                                      #'identificatie'
    nen3610:domein                               "http://example.com/gemeente/areaaldata/"^^xsd:anyURI ; #'domein' (Voorbeeld gemeente data)
    imbor:4e721262-e6e2-41df-bb99-0b6693e32435  imbor-domeinwaarde:01a31554-111c-4765-82cb-79f0b178eb8e ; #'status' (In gebruik)
    nen2660:consistOf                            data:vbf1_m ;                                 #'bestaat uit Beton'
    .

## Fundering - Materiaal
data:vbf1_m
    a                                           imbor:52ab27f2-fb67-4752-8cfc-ac4f3638df4e ;   #'Beton'
    nen3610:identificatie                        "vbf1_m" ;                                   #'identificatie'
    nen3610:domein                               "http://example.com/gemeente/areaaldata/"^^xsd:anyURI ; #'domein' (Voorbeeld gemeente data)
    #### 2 opties: 'aantal palen' als attribuut op Paalfundering (moet in IMBOR toegevoegd) OF ga je de Palen apart doen?
    .

    

## ============================================================
## Lichtmasten
## ============================================================

## Lichtmast 1
data:vblm1
    a                                           imbor:e5d5a58c-bb19-4d49-8bf0-d1ea48a5487e ;    #'Lichtmast'
    nen2660:hasBoundary 
    [
        a geo:Geometry ;
        a imbor:bdb53bb7-defc-4055-b047-271c5edda82a ; #GM_Point
        geo:asWKT "<http://www.opengis.net/def/crs/EPSG/0/28992>POINT((125145 502283))"^^geo:wktLiteral ;
    ]    ; #'geometrie'
    nen3610:identificatie                        "vblm1" ;                                      #'identificatie'
    nen3610:domein                               "http://example.com/gemeente/areaaldata/"^^xsd:anyURI ; #'domein' (Voorbeeld gemeente data)
    imbor:4e721262-e6e2-41df-bb99-0b6693e32435  imbor-domeinwaarde:01a31554-111c-4765-82cb-79f0b178eb8e ; #'status' (In gebruik)
    nen2660:isConnectedTo                       data:vblm1_pa1 ;                                #'is verbonden met Paaltoparmatuur'
    .

## Lichtmast 1 - Paaltoparmatuur
data:vblm1_pa1
    a                                           imbor:91484875-ba8a-443e-bb2a-2c5c89f24769 ;    #'Paaltoparmatuur'
    nen3610:identificatie                        "vblm1_pa1" ;                                  #'identificatie'
    nen3610:domein                               "http://example.com/gemeente/areaaldata/"^^xsd:anyURI ; #'domein' (Voorbeeld gemeente data)
    imbor:4e721262-e6e2-41df-bb99-0b6693e32435  imbor-domeinwaarde:01a31554-111c-4765-82cb-79f0b178eb8e ; #'status' (In gebruik)
    nen2660:isConnectedTo                        data:vblm1_pa1_lb1 ;                           #'is verbonden met Lichtbron'
    .

